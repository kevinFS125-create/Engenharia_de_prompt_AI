Crie um sistema de jogos gratis
Boa ideia, Kevin! Vamos montar um sistema de jogos grátis em Python. A ideia é ter um menu inicial onde o usuário pode escolher entre alguns joguinhos simples, como:

Adivinhação de número

Jogo da forca

Pedra, papel ou tesoura

Aqui está um exemplo de código:

python
import random

def jogo_adivinhacao():
    numero = random.randint(1, 10)
    tentativa = int(input("Adivinhe o número entre 1 e 10: "))
    if tentativa == numero:
        print("Parabéns! Você acertou!")
    else:
        print(f"Que pena! O número era {numero}.")

def jogo_forca():
    palavras = ["python", "jogo", "gratis", "computador"]
    palavra = random.choice(palavras)
    letras_descobertas = ["_"] * len(palavra)
    tentativas = 6

    while tentativas > 0 and "_" in letras_descobertas:
        print(" ".join(letras_descobertas))
        letra = input("Digite uma letra: ").lower()
        if letra in palavra:
            for i, l in enumerate(palavra):
                if l == letra:
                    letras_descobertas[i] = letra
        else:
            tentativas -= 1
            print(f"Letra errada! Restam {tentativas} tentativas.")

    if "_" not in letras_descobertas:
        print(f"Você venceu! A palavra era {palavra}.")
    else:
        print(f"Você perdeu! A palavra era {palavra}.")

def jogo_pedra_papel_tesoura():
    opcoes = ["pedra", "papel", "tesoura"]
    escolha_usuario = input("Escolha pedra, papel ou tesoura: ").lower()
    escolha_pc = random.choice(opcoes)
    print(f"O computador escolheu {escolha_pc}.")

    if escolha_usuario == escolha_pc:
        print("Empate!")
    elif (escolha_usuario == "pedra" and escolha_pc == "tesoura") or \
         (escolha_usuario == "papel" and escolha_pc == "pedra") or \
         (escolha_usuario == "tesoura" and escolha_pc == "papel"):
        print("Você venceu!")
    else:
        print("Você perdeu!")

def menu():
    while True:
        print("\n=== Sistema de Jogos Grátis ===")
        print("1 - Adivinhação")
        print("2 - Forca")
        print("3 - Pedra, Papel ou Tesoura")
        print("0 - Sair")

        escolha = input("Escolha um jogo: ")
        if escolha == "1":
            jogo_adivinhacao()
        elif escolha == "2":
            jogo_forca()
        elif escolha == "3":
            jogo_pedra_papel_tesoura()
        elif escolha == "0":
            print("Saindo... Obrigado por jogar!")
            break
        else:
            print("Opção inválida!")

# Executa o menu principal
menu()
Esse código cria um mini sistema de jogos grátis em Python, com um menu interativo.

