# Sistema de Cadastro e Login em Python
# Autor: Kevin (estudante iniciante)
# Objetivo: Criar um programa que permita cadastrar usuários e realizar login

# Dicionário para armazenar os cadastros
# A chave será o nome de usuário e o valor será a senha
usuarios = {}

def cadastrar_usuario():
    """
    Função responsável por cadastrar um novo usuário.
    Ela pede um nome de usuário e uma senha, e armazena no dicionário 'usuarios'.
    """
    print("\n=== Cadastro de Usuário ===")
    usuario = input("Digite um nome de usuário: ")
    
    # Verifica se o usuário já existe
    if usuario in usuarios:
        print("Usuário já cadastrado! Tente outro nome.")
    else:
        senha = input("Digite uma senha: ")
        usuarios[usuario] = senha  # Armazena no dicionário
        print("Cadastro realizado com sucesso!")

def login_usuario():
    """
    Função responsável por realizar o login.
    Ela pede nome de usuário e senha, e verifica se estão corretos.
    """
    print("\n=== Login de Usuário ===")
    usuario = input("Digite seu nome de usuário: ")
    senha = input("Digite sua senha: ")

    # Verifica se o usuário existe e se a senha está correta
    if usuario in usuarios and usuarios[usuario] == senha:
        print("Login realizado com sucesso! Bem-vindo,", usuario)
    else:
        print("Usuário ou senha incorretos!")

def menu():
    """
    Função principal que exibe o menu de opções.
    O usuário pode escolher cadastrar, fazer login ou sair.
    """
    while True:
        print("\n=== Sistema de Cadastro e Login ===")
        print("1 - Cadastrar novo usuário")
        print("2 - Fazer login")
        print("0 - Sair")

        opcao = input("Escolha uma opção: ")

        if opcao == "1":
            cadastrar_usuario()
        elif opcao == "2":
            login_usuario()
        elif opcao == "0":
            print("Saindo... Obrigado por usar o sistema!")
            break
        else:
            print("Opção inválida! Tente novamente.")

# Executa o programa chamando o menu principal
menu()
O que esse código faz:
Cria um dicionário para armazenar usuários e senhas.

Permite cadastrar novos usuários.

Permite fazer login verificando se o usuário existe e se a senha está correta.

Usa um menu interativo para navegar entre as opções.

👉 Esse é um ótimo exercício para praticar funções, estruturas de repetição e condicionais em Python.
